{
  "venues": {
    "neurips": {
      "name": "NeurIPS",
      "type": "conference",
      "year": 2026,
      "template": {
        "entry_tex": "neurips/main.tex",
        "required_markers": ["\\usepackage{neurips_2026}"]
      },
      "format": {
        "abstract_max_words": "one paragraph, ~250 words",
        "page_limit": 9,
        "page_count_includes": ["main body", "references"],
        "page_count_excludes": ["appendix"]
      },
      "citation": {
        "style": "author-year",
        "package": "natbib",
        "commands": ["\\citep{}", "\\citet{}"],
        "bib_style": "provided by template"
      },
      "figures": { "min": 5, "format": "pdf, png, eps", "caption_position": "bottom" },
      "tables": { "min": 1, "style": "booktabs", "caption_position": "top" },
      "requirements": {
        "anonymous": true,
        "ethics_statement": "Required for some submissions",
        "reproducibility_checklist": true,
        "supplementary_materials": "allowed",
        "checklist": "Required: checklist.tex must be included"
      },
      "ablation": { "required": true, "description": "Ablation studies are expected" }
    },

    "icml": {
      "name": "ICML",
      "type": "conference",
      "year": 2026,
      "template": {
        "entry_tex": "icml/main.tex",
        "required_markers": ["icml2025"]
      },
      "format": {
        "abstract_max_words": "one paragraph, ~4-6 sentences",
        "page_limit": 8,
        "page_count_includes": ["main body"],
        "page_count_excludes": ["references", "appendix", "impact statement"]
      },
      "citation": {
        "style": "author-year",
        "package": "natbib",
        "commands": ["\\citep{}", "\\citet{}"],
        "bib_style": "icml2025.bst"
      },
      "figures": { "min": 5, "format": "pdf, png, eps", "caption_position": "bottom" },
      "tables": { "min": 1, "style": "booktabs", "caption_position": "top" },
      "requirements": {
        "anonymous": true,
        "ethics_statement": "Required",
        "reproducibility_checklist": true,
        "supplementary_materials": "allowed"
      },
      "ablation": { "required": true, "description": "Ablation studies expected" }
    },

    "iclr": {
      "name": "ICLR",
      "type": "conference",
      "year": 2026,
      "template": {
        "entry_tex": "iclr/main.tex",
        "required_markers": ["\\usepackage{iclr2025_conference,times}"]
      },
      "format": {
        "abstract_max_words": "one paragraph, ~250 words",
        "page_limit": 9,
        "page_count_includes": ["main body"],
        "page_count_excludes": ["references", "appendix"]
      },
      "citation": {
        "style": "author-year",
        "package": "natbib",
        "commands": ["\\citep{}", "\\citet{}"],
        "bib_style": "iclr2025_conference.bst"
      },
      "figures": { "min": 5, "format": "pdf, png, eps", "caption_position": "bottom" },
      "tables": { "min": 1, "style": "booktabs", "caption_position": "top" },
      "requirements": {
        "anonymous": true,
        "ethics_statement": "Required for some",
        "reproducibility_checklist": false,
        "supplementary_materials": "allowed"
      },
      "ablation": { "required": true, "description": "Ablation studies expected" }
    },

    "aaai": {
      "name": "AAAI",
      "type": "conference",
      "year": 2026,
      "template": {
        "entry_tex": "aaai/main.tex",
        "required_markers": ["aaai2026"]
      },
      "format": {
        "abstract_max_words": "one paragraph, ~200 words",
        "page_limit": 7,
        "page_count_includes": ["main body", "references"],
        "page_count_note": "7 pages main text + unlimited references"
      },
      "citation": {
        "style": "author-year",
        "package": "natbib",
        "commands": ["\\citep{}", "\\citet{}"],
        "bib_style": "aaai2026.bst"
      },
      "figures": { "min": 4, "format": "pdf, png, eps", "caption_position": "bottom" },
      "tables": { "min": 1, "style": "booktabs", "caption_position": "top" },
      "requirements": {
        "anonymous": true,
        "ethics_statement": "Required",
        "reproducibility_checklist": false,
        "supplementary_materials": "not allowed",
        "prohibitions": "No color figures, no URLs in references"
      },
      "ablation": { "required": true, "description": "Ablation studies expected" }
    },

    "nature": {
      "name": "Nature",
      "type": "journal",
      "publisher": "Springer Nature",
      "scope": "High-impact interdisciplinary research with broad scientific significance",
      "template": {
        "entry_tex": "nature/main.tex",
        "required_markers": ["\\documentclass[pdflatex,sn-mathphys-num]{sn-jnl}"],
        "note": "Bundled Springer Nature template; adjust the documentclass option to the target Nature-family venue as needed"
      },
      "format": {
        "abstract_max_words": "~150-200 words depending on article type",
        "page_limit": 8,
        "page_count_includes": ["main text", "figures", "references"],
        "page_count_note": "Actual limits depend on article type and journal instructions"
      },
      "citation": {
        "style": "numeric",
        "package": "natbib-compatible via sn-jnl",
        "commands": ["\\cite{}"],
        "bib_style": "sn-nature.bst"
      },
      "figures": { "min": 2, "format": "eps, pdf, png", "caption_position": "bottom" },
      "tables": { "min": 0, "style": "standard", "caption_position": "top" },
      "requirements": {
        "anonymous": false,
        "ethics_statement": "Required where applicable",
        "reproducibility_checklist": false,
        "supplementary_materials": "allowed",
        "notes": "Venue-specific editorial policies take precedence; template should usually remain a single manuscript file"
      },
      "ablation": { "required": false, "description": "Only when central to the paper's claims" }
    },

    "science": {
      "name": "Science",
      "type": "journal",
      "publisher": "AAAS",
      "scope": "Broad scientific advances of strong cross-disciplinary interest",
      "template": {
        "entry_tex": "science/main.tex",
        "required_markers": ["\\usepackage{scicite}"],
        "note": "Bundled Science-family template; keep the manuscript simple and avoid adding extra style packages"
      },
      "format": {
        "abstract_max_words": "journal/article-type dependent; usually concise",
        "page_limit": 10,
        "page_count_includes": ["main text", "figures", "references", "supplement list"],
        "page_count_note": "Actual limits depend on article type and journal instructions"
      },
      "citation": {
        "style": "numeric",
        "package": "scicite",
        "commands": ["\\cite{}"],
        "bib_style": "sciencemag.bst"
      },
      "figures": { "min": 2, "format": "pdf, png, eps", "caption_position": "bottom" },
      "tables": { "min": 0, "style": "standard", "caption_position": "top" },
      "requirements": {
        "anonymous": false,
        "ethics_statement": "Required where applicable",
        "reproducibility_checklist": false,
        "supplementary_materials": "common",
        "notes": "The bundled template includes main text plus supplement conventions; article-specific author instructions still govern"
      },
      "ablation": { "required": false, "description": "Only when central to the scientific claim" }
    },


    "pre": {
      "name": "Physical Review E",
      "type": "journal",
      "publisher": "APS",
      "scope": "Statistical physics, nonlinear dynamics, complex systems, soft matter, biological physics",
      "template": {
        "entry_tex": "aps/main.tex",
        "required_markers": ["aps,"]
      },
      "format": {
        "abstract_max_words": 250,
        "page_limit": 10,
        "page_count_includes": ["full paper"]
      },
      "citation": {
        "style": "numeric",
        "package": "revtex-natbib",
        "commands": ["\\cite{}", "\\citep{}", "\\citet{}"],
        "bib_style": "apsrev4-1.bst"
      },
      "figures": { "min": 3, "format": "eps, pdf, tiff", "caption_position": "bottom" },
      "tables": { "min": 1, "style": "revtex", "caption_position": "top" },
      "requirements": {
        "anonymous": false,
        "ethics_statement": "Required",
        "reproducibility_checklist": false,
        "supplementary_materials": "allowed",
        "data_availability": "Required: data underlying study must be available"
      },
      "ablation": { "required": false, "description": "N/A for physics" }
    },

