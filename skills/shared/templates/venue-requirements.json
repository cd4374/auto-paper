    "prl": {
      "name": "Physical Review Letters",
      "type": "journal",
      "publisher": "APS",
      "scope": "Rapid communications, important original research in physics",
      "template": {
        "entry_tex": "aps/main.tex",
        "required_markers": ["aps,"]
      },
      "format": {
        "abstract_max_chars": 600,
        "abstract_max_words": "~150 words (600 characters including spaces)",
        "word_limit": 3750,
        "page_count_includes": ["full paper"],
        "page_count_note": "Max 3750 words for body (excludes abstract, references); typically 4-6 pages"
      },
      "citation": {
        "style": "numeric",
        "package": "revtex-natbib",
        "commands": ["\\cite{}", "\\citep{}", "\\citet{}"],
        "bib_style": "apsrev4-1.bst"
